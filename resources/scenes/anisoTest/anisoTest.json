// Anisotropic metal BRDF showcase. Three flat steel panels differ only in
// anisotropy: the left is isotropic (round highlight from the key light),
// the middle stretched along +tangent, the right stretched along +bitangent.
// Panels are flat so the tangent direction is consistent across the surface
// and the anisotropy is visible as a streak instead of a blob.

{
	"mainCamera": {
		"location": [0, 3.5, 1.8],
		"angle": [-55, 0, 0],
		"fieldOfView": 55,
		"exposure": 1.0
	},

	"envmap": {
		"texture": "../../textures/sky_sun.hdr",
		"intensity": 0.3,
		"rotation": 60
	},

	"world": {
		"keyLight": {
			"location": [0, 5.0, -2.7],
			"angle": [180, 0, 0],
			"scale": [0.5, 1, 0.5],
			"mesh": { "type": "plane" },
			"mat": { "emission": 400.0 }
		},

		"floor": {
			"location": [0, 0, 0],
			"scale": [12, 1, 12],
			"mesh": { "type": "plane" },
			"mat": { "color": [0.25, 0.25, 0.28], "roughness": 0.6 }
		},

		"iso": {
