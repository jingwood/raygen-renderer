// Phase 3 demo: scattering-dominant volume + fBm density field. Looks like
// a small cumulus puff lit by a sun-driven envmap. Scattering picks up the
// envmap so the cloud lights up from the sun direction; the fBm modulator
// carves the soft edges and internal wisps that uniform fog can't produce.
{
  "mainCamera": {
    "location": [0, 0.6, 4.5],
    "angle": [-3, 0, 0],
    "fieldOfView": 45,
    "exposure": 1.0
  },

  "envmap": {
    "texture": "../../textures/sky_sun.hdr",
    "intensity": 2.0
  },

  "world": {
    "Floor": {
      "location": [0, -1.0, 0],
      "scale": [12, 1, 12],
      "mesh": { "type": "plane" },
      "mat": { "color": "#666666", "diffuse": 1.0 }
    },

    "Cloud": {
      "location": [0, 0.5, 0],
      "scale": [2.0, 1.0, 1.0],
      "mesh": { "type": "cube" },
      "mat": { "color": "#ffffff", "transparency": 1.0 },
      "medium": {
        "sigma_a": [0.05, 0.05, 0.05],
        "sigma_s": [3.0, 3.0, 3.0],
        "g": 0.6,
        "density": 1.0,
        "densityField":   "fbm",
        "noiseFrequency": 1.6,
        "noiseOctaves":   4,
        "noiseGain":      0.5,
        "noiseLacunarity": 2.0,
        "noiseAmplitude": 1.4,
        "noiseBias":     -0.25
      }
    }
  }
}
