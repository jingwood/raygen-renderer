// Phase 3 demo: jet-engine flame with fBm density modulation. Same cone
// emission as Phase 2's jetFlame.json, but the noise field breaks the smooth
// gaussian into spitting tongues and gaps. Higher noiseFrequency = finer
// turbulence; noiseBias = -0.3 is what carves the visible empty pockets.
{
  "mainCamera": {
    "location": [0, 0.4, 3.5],
    "angle": [-3, 0, 0],
    "fieldOfView": 45,
    "exposure": 0.7
  },
	
  "envmap": {
		"texture": "../../textures/sky_sun.hdr",
		"intensity": 2,
		"rotation": 20
	},

  "world": {
    "Floor": {
      "location": [0, -1.0, 0],
      "scale": [12, 1, 12],
      "mesh": { "type": "plane" },
      "mat": { "color": "#222222", "diffuse": 1.0 }
    },

    "BackWall": {
      "location": [0, 1.0, -3],
      "scale": [12, 4, 1],
      "mesh": { "type": "plane" },
      "angle": [90, 0, 0],
      "mat": { "color": "#1a1a1a", "diffuse": 1.0 }
    },

    "Nozzle": {
      "location": [0.6, 0.4, 0],
      "scale": [0.18, 0.18, 0.18],
      "mesh": { "type": "sphere" },
      "mat": { "color": "#1a1a1a", "glossy": 0.7, "metallic": 1.0, "roughness": 0.35 }
    },

    "FlameVolume": {
      "location": [-0.2, 0.4, 0],
      "scale": [1.6, 0.7, 0.7],
      "mesh": { "type": "cube" },
      "mat": { "color": "#ffffff", "transparency": 1.0 },
      "medium": {
        "sigma_a": [0, 0, 0],
        "sigma_s": [0, 0, 0],
        "emissionMode": "cone",
        "coneOrigin":   [0.6, 0.4, 0],
        "coneAxis":     [-1, 0, 0],
        "coneLength":   1.6,
        "coneRadius":   0.35,
        "coneInner":    [4, 6, 12],
        "coneOuter":    [10, 3, 0.4],
        "coneIntensity": 30.0,
        "conePeakAxial": 0.2,
        "conePeakSharpness": 3.5,
        "coneEmissionSamples": 12,
        "densityField":   "fbm",
        "noiseFrequency": 4.0,
        "noiseOctaves":   4,
        "noiseGain":      0.55,
        "noiseLacunarity": 2.1,
        "noiseAmplitude": 1.6,
        "noiseBias":     -0.3
      }
    }
  }
}
