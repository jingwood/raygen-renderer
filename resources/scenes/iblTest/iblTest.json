// IBL / environment lighting test. No area or point light — the scene is
// lit entirely by the equirectangular sky texture wrapped around infinity.
// A glass sphere + a rough diffuse sphere + a metallic-ish sphere sit on a
// checker floor so every surface shows a different IBL response:
//  - glass sphere refracts the sun and ground through its body
//  - diffuse sphere averages the whole sky into soft shading
//  - glossy sphere mirrors the hot sun disc and horizon gradient
//
// envmapRotation spins the sky around Y without re-baking; envmapIntensity
// scales the radiance (set >1 to push the sun brighter for caustics).

{
	"mainCamera": {
		"location": [0, 1.5, 6.0],
		"angle": [-6, 0, 0],
		"fieldOfView": 55,
		"exposure": 1.0
	},

	"envmap": {
		"texture": "../../textures/sky_test.jpg",
		"intensity": 1.8,
		"rotation": 0
	},

	"world": {
		"floor": {
			"location": [0, -0.5, 0],
			"scale": [30, 1, 30],
			"mesh": { "type": "plane" },
			"mat": {
				"tex": "../../textures/checkerboard.jpg",
				"color": [0.9, 0.9, 0.9],
				"texTiling": [12, 12]
			}
		},

		"diffuse_ball": {
			"location": [-2.2, 0.2, 0],
			"scale": [0.7, 0.7, 0.7],
			"mesh": { "type": "sphere" },
			"mat": { "color": [0.95, 0.4, 0.3], "roughness": 0.8 }
		},

		"glass_ball": {
			"location": [0, 0.2, 0],
			"scale": [0.7, 0.7, 0.7],
			"mesh": { "type": "sphere" },
			"mat": { "color": [1.0, 1.0, 1.0], "refraction": 1.0, "refractionRatio": 1.5, "chromaDispersion": 0.03, "roughness": 0.0 }
		},

		"glossy_ball": {
			"location": [2.2, 0.2, 0],
			"scale": [0.7, 0.7, 0.7],
			"mesh": { "type": "sphere" },
			"mat": { "color": [0.85, 0.85, 0.9], "glossy": 1.0, "roughness": 0.05 }
		}
	}
}
