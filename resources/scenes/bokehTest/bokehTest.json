// Bokeh / DOF demo. Round "camera bokeh" — a small subject is in focus,
// and behind it a scatter of tiny sphere emitters turn into bright round
// out-of-focus discs. apertureBlades=0 gives circular bokeh; try 5/6/7/8
// to swap to an n-sided iris.

{
	"mainCamera": {
		"location": [0, 0.3, 5.0],
		"angle": [5, 0, 0],
		"fieldOfView": 45,
		"depthOfField": 4.5,
		"aperture": 2.8,
		"apertureBlades": 0,
		"apertureRotation": 10,
		"exposure": 1.0
	},

	"world": {
		"angle": [0, 0, 0],

		"keyLight": {
			"location": [-1.5, 4.0, 1.5],
			"angle": [180, 0, 0],
			"scale": [1.5, 1, 1.5],
			"mesh": { "type": "plane" },
			"mat": { "emission": 15.0 }
		},

		"floor": {
			"location": [0, -0.3, 0],
			"scale": [40, 1, 40],
			"mesh": { "type": "plane" },
			"mat": { "color": [0.22, 0.22, 0.25] }
		},

		// Focused subject: small diffuse sphere on the focal plane.
		"subject": {
			"location": [0, 0.2, 0.5],
			"scale": [0.45, 0.45, 0.45],
			"mesh": { "type": "sphere" },
			"mat": { "color": [0.95, 0.35, 0.2], "glossy": 0.5, "metallic": 1,
        "refraction": 0.0, "roughness": 0.1 }
		},

		"backdrop": {
			"location": [0, 4, -10],
			"angle": [90, 0, 0],
			"scale": [40, 1, 10],
			"mesh": { "type": "plane" },
			"mat": { "color": [0.15, 0.15, 0.18] }
		},

		// Emitter spheres. Radius ≈ 0.15 gives each one a visible angular
		// footprint so the aperture sampling actually lands on it; scale*2
		// (since SphereMesh has radius 1 by default) → 0.15 world radius.
		// Bright emission so the centre saturates into the tone map.
		"bokeh_01": { "location": [-3.2, 1.8, -3], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [1.0, 0.25, 0.15] } },
		"bokeh_02": { "location": [-2.0, 2.5, -4], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [0.15, 0.25, 1.0] } },
		"bokeh_03": { "location": [-0.8, 0.9, -5], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [1.0, 1.0, 0.2] } },
		"bokeh_04": { "location": [ 1.1, 1.6, -3.5], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" }, "mat": { "emission": 300, "color": [0.2, 1.0, 0.35] } },
		"bokeh_05": { "location": [ 2.2, 0.6, -4.5], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" }, "mat": { "emission": 300, "color": [1.0, 0.25, 0.35] } },
		"bokeh_06": { "location": [ 3.0, 2.3, -3], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [0.25, 0.25, 1.0] } },
		"bokeh_07": { "location": [-3.8, 0.8, -6], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [1.0, 0.3, 0.1] } },
		"bokeh_08": { "location": [ 3.8, 1.2, -7], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [0.1, 0.2, 1.0] } },
		"bokeh_09": { "location": [-0.3, 3.2, -5], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [1.0, 0.0, 1.0] } },
		"bokeh_10": { "location": [ 2.0, 2.9, -7], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [1.0, 0.2, 0.3] } },
		"bokeh_11": { "location": [-2.8, 2.7, -6], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [0.9, 1.0, 0.2] } },
		"bokeh_12": { "location": [ 0.7, 0.4, -6], "scale": [0.15, 0.15, 0.15], "mesh": { "type": "sphere" },   "mat": { "emission": 300, "color": [1.0, 0.25, 0.1] } }
	}
}
