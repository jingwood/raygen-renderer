// Bokeh / DOF stress scene. A small diffuse subject sits close to the
// camera in focus; behind it is a field of point-like emitters at varying
// depths, each acting as a pin-prick light so its out-of-focus image is a
// clean copy of the aperture shape. Change camera.apertureBlades to compare
// 0 (circular), 5 / 6 / 7 / 8 polygon bokeh.

{
	"mainCamera": {
		"location": [0, 1.0, 5.0],
		"angle": [-6, 0, 0],
		"fieldOfView": 55,
		"depthOfField": 5.0,
		"aperture": 0.8,
		"apertureBlades": 6,
		"apertureRotation": 15,
		"exposure": 1.0
	},

	"world": {
		"angle": [0, 0, 0],

		"keyLight": {
			"location": [0, 4.5, 2.0],
			"angle": [180, 0, 0],
			"scale": [3, 1, 3],
			"mesh": { "type": "plane" },
			"mat": { "emission": 12.0 }
		},

		"floor": {
			"location": [0, -0.5, 0],
			"scale": [30, 1, 30],
			"mesh": { "type": "plane" },
			"mat": {
				"tex": "../../textures/checkerboard.jpg",
				"color": [0.9, 0.9, 0.9],
				"texTiling": [10, 10]
			}
		},

		"subject": {
			"location": [0, 0.0, 0],
			"scale": [0.8, 1.0, 0.8],
			"mesh": { "type": "cube" },
			"mat": { "color": [0.95, 0.35, 0.2], "roughness": 0.6 }
		},

		"bokeh_a": { "location": [-4.0, 0.8, -3.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [1.0, 0.7, 0.4] } },
		"bokeh_b": { "location": [-2.8, 1.4, -4.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [0.4, 0.7, 1.0] } },
		"bokeh_c": { "location": [-1.5, 0.6, -6.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [1.0, 1.0, 0.6] } },
		"bokeh_d": { "location": [ 0.6, 1.2, -5.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [0.6, 1.0, 0.7] } },
		"bokeh_e": { "location": [ 2.0, 0.5, -7.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [1.0, 0.5, 0.8] } },
		"bokeh_f": { "location": [ 3.2, 1.6, -4.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [0.8, 0.8, 1.0] } },
		"bokeh_g": { "location": [ 4.3, 0.9, -6.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [1.0, 0.9, 0.5] } },
		"bokeh_h": { "location": [-3.2, 2.2, -7.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [0.9, 0.5, 0.3] } },
		"bokeh_i": { "location": [ 1.8, 2.4, -8.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [0.5, 0.9, 1.0] } },
		"bokeh_j": { "location": [-0.4, 0.3, -9.0], "scale": [0.05, 0.05, 0.05], "mesh": { "type": "cube" }, "mat": { "emission": 3000, "color": [1.0, 1.0, 1.0] } }
	}
}
